{
  "cacheBust": false,
  "scriptCacheTtlSeconds": 900,
  "updateCheckIntervalSeconds": 3600,
  "scripts": [
    {
      "url": "Jira.js",
      "match": [
        "*://*/secure/RapidBoard.jspa*"
      ]
    },
    {
      "url": "Jira.focus.js",
      "match": [
        "*://*/secure/*",
        "*://*/browse/*",
        "*://*/projects/*",
        "*://*/issues/*",
        "*://*/jira/*",
        "*://*/servicedesk/*",
        "*://*/plugins/*"
      ],
      "exclude-match": [
        "*://*/secure/RapidBoard.jspa*"
      ]
    }
  ]
}
